      "label": "Final CTA heading",
      "default": "Ready to stop guessing through your reps?"
    },
    {
      "type": "textarea",
      "id": "final_text",
      "label": "Final CTA body text",
      "default": "LevelUp gives you the thick-grip arm-growth story buyers already want, then adds the patented balance feedback that makes the offer feel smarter, more useful, and easier to justify."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LevelUp Mobile Product"
    }
  ]
}
{% endschema %}
