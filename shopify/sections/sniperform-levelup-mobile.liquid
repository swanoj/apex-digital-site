        <span class="snf-mob-spec-title">50mm × 100mm · 85g each grip</span>
      </div>
      <span class="snf-mob-spec-chevron">+</span>
    </summary>
    <p class="snf-mob-spec-body">Large enough to change grip demand fast, compact enough to carry easily, and light enough to feel practical as an everyday gym tool.</p>
  </details>
</div>

<!-- ── COMPARISON ─────────────────────────────────────── -->
<div style="height:12px;background:var(--bg)"></div>
<div class="snf-mob-compare fade-up">
  <p class="snf-mob-compare-eyebrow mono">Comparison</p>
  <h2>LevelUp vs a standard thick grip.</h2>
  <div class="snf-mob-compare-grid">
    <div class="snf-mob-compare-col">
      <div class="snf-mob-compare-col-head">Standard grip</div>
      <div class="snf-mob-compare-feat yes"><span class="dot">✓</span>Thick-grip stimulation</div>
      <div class="snf-mob-compare-feat no"><span class="dot">✕</span>Level feedback</div>
      <div class="snf-mob-compare-feat no"><span class="dot">✕</span>Imbalance cue</div>
      <div class="snf-mob-compare-feat no"><span class="dot">✕</span>Quick-lock mount</div>
      <div class="snf-mob-compare-feat no"><span class="dot">✕</span>Patented tech</div>
    </div>
    <div class="snf-mob-compare-col is-snf">
      <div class="snf-mob-compare-col-head">Sniperform LevelUp</div>
      <div class="snf-mob-compare-feat snf-yes"><span class="dot">✓</span>Thick-grip stimulation</div>
      <div class="snf-mob-compare-feat snf-yes"><span class="dot">✓</span>Level feedback</div>
      <div class="snf-mob-compare-feat snf-yes"><span class="dot">✓</span>Imbalance cue</div>
      <div class="snf-mob-compare-feat snf-yes"><span class="dot">✓</span>Quick-lock mount</div>
      <div class="snf-mob-compare-feat snf-yes"><span class="dot">✓</span>Patented tech</div>
    </div>
  </div>
</div>

<!-- ── FAQ ────────────────────────────────────────────── -->
<div class="snf-mob-faq">
  <div class="snf-mob-faq-head fade-up">
    <p class="snf-mob-faq-eyebrow mono">FAQ</p>
    <h2>Common questions.</h2>
  </div>
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'faq' %}
        <details class="snf-mob-faq-item"{% if forloop.first %} open{% endif %} {{ block.shopify_attributes }}>
          <summary class="snf-mob-faq-summary">
            {{ block.settings.question }}
            <span class="snf-mob-faq-plus">+</span>
          </summary>
          <p class="snf-mob-faq-answer">{{ block.settings.answer }}</p>
        </details>
    {% endcase %}
  {% endfor %}
</div>

<!-- ── FOUNDER QUOTE ──────────────────────────────────── -->
<div class="snf-mob-founder fade-up">
  <p class="snf-mob-founder-eyebrow mono">The founder story</p>
  <blockquote class="snf-mob-founder-quote">{{ section.settings.founder_quote }}</blockquote>
  <cite class="snf-mob-founder-cite">{{ section.settings.founder_attribution }}</cite>
</div>

<!-- ── FINAL CTA ──────────────────────────────────────── -->
<div class="snf-mob-final fade-up">
  <p class="snf-mob-final-eyebrow mono">Ready to level up?</p>
  <h2>{{ section.settings.final_heading }}</h2>
  <p>{{ section.settings.final_text }}</p>
  <div class="snf-mob-final-bullets">
    <span class="snf-mob-final-bullet">Free shaker auto-applied while stocks last</span>
    <span class="snf-mob-final-bullet">30-day money-back guarantee</span>
    <span class="snf-mob-final-bullet">Fits 28–32mm bars and dumbbells</span>
    <span class="snf-mob-final-bullet">Same-day dispatch before 2pm AEDT</span>
  </div>
  <div class="snf-mob-final-btns">
    <a class="snf-mob-final-atc" href="#snf-m-buy-{{ section.id }}">Get LevelUp Grips</a>
    <a class="snf-mob-final-ghost" href="{{ product.url }}">View full product details</a>
  </div>
</div>

<!-- ── STICKY BAR ─────────────────────────────────────── -->
<div class="snf-mob-sticky" data-m-sticky>
  <div class="snf-mob-sticky-copy">
    <strong>{{ product.title }}</strong>
    <span>{{ current_variant.price | money }} · Free shaker while stocks last</span>
  </div>
  <a class="snf-mob-sticky-btn" href="#snf-m-buy-{{ section.id }}">Add to cart</a>
</div>

<script>
(function(){
  const root = document.getElementById("snf-mob-{{ section.id }}");
  if (!root) return;

  /* ── GALLERY ──────────────────────────────────────── */
  const track = root.querySelector("[data-gallery-track]");
  const dotsWrap = root.querySelector("[data-gallery-dots]");
  if (track && dotsWrap) {
    const slides = [...track.querySelectorAll(".snf-mob-gallery-slide")];
    const count = slides.length;
    if (count > 1) {
      dotsWrap.innerHTML = slides.map((_,i) =>
        `<span class="${i===0?"active":""}"></span>`).join("");
      const dots = [...dotsWrap.querySelectorAll("span")];
      let lastIdx = 0;
      const update = () => {
        const idx = Math.round(track.scrollLeft / track.offsetWidth);
        if (idx !== lastIdx) {
          dots[lastIdx].classList.remove("active");
          dots[idx] && dots[idx].classList.add("active");
          lastIdx = idx;
        }
      };
      track.addEventListener("scroll", update, { passive: true });
    } else {
      dotsWrap.style.display = "none";
    }
  }

  /* ── USE CASES ────────────────────────────────────── */
  const useCases = [
    {
      id:"rows",
      label:"Rows",
      kicker:"Rows",
      title:"Rows reward the thicker handle and the level cue at the same time.",
      text:"On rows, LevelUp drives more grip demand while showing when the pull starts to twist or one side begins to dominate. One of the fastest lifts for making the product feel immediately useful.",
      image:"https://sniperform.com.au/cdn/shop/files/0F3A2557_square_crop_2000.webp?v=1769487620&width=900",
      benefits:["More squeeze through the hands, forearms and biceps from rep one.","A visible cue to stop the bar path drifting as fatigue builds.","An easy first use case for serious back and arm work."]
    },
    {
      id:"curls",
      label:"Curls",
      kicker:"Curls",
      title:"Curls make the bigger-arm promise obvious.",
      text:"LevelUp makes curls feel harder through the grip immediately, which keeps the growth story simple. The level cue adds a layer of control so the pitch is not just bigger pump, but cleaner work through both arms.",
      image:"https://sniperform.com.au/cdn/shop/files/0F3A2480_square_crop_2000.webp?v=1769488611&width=900",
      benefits:["Supports the thick-grip arm-growth angle without changing the movement.","Keeps one side from quietly taking over as the set gets messy.","Makes the product feel instantly relevant for arm-day buyers."]
    },
    {
      id:"presses",
      label:"Presses",
      kicker:"Presses",
      title:"Pressing is where the alignment cue starts to feel protective.",
      text:"Presses expose wrist and shoulder drift fast. The visible level cue helps the lifter correct sooner, which makes LevelUp feel like performance equipment with a real control benefit.",
      image:"https://sniperform.com.au/cdn/shop/files/0F3A3029_square_crop_2000.webp?v=1767933896&width=900",
      benefits:["Strengthens the connection between balanced reps and cleaner joint mechanics.","Makes the patented feedback system feel serious, not decorative.","Adds more grip demand without stripping the movement of control."]
    },
    {
      id:"pulls",
      label:"Pulls",
      kicker:"Pulls",
      title:"Heavy pulls turn grip strength into the feature, not the bottleneck.",
      text:"When the handle gets thicker, pulling movements become a real test of grip capacity. That expands LevelUp beyond arm-day novelty into something advanced lifters can justify across multiple sessions each week.",
      image:"https://sniperform.com.au/cdn/shop/files/0F3A2747.png?v=1738733865&width=900",
      benefits:["Supports the hand-crushing grip strength angle.","Shows the tool belongs in more than one exercise slot.","Builds a more serious performance story for advanced lifters."]
    }
  ];

  const navWrap = root.querySelector("[data-m-use-nav]");
  const useImg = root.querySelector("[data-m-use-img]");
  const useKicker = root.querySelector("[data-m-use-kicker]");
  const useTitle = root.querySelector("[data-m-use-title]");
  const useText = root.querySelector("[data-m-use-text]");
  const useBenefits = root.querySelector("[data-m-use-benefits]");

  function setUseCase(id) {
    const item = useCases.find(u => u.id === id) || useCases[0];
    navWrap.innerHTML = useCases.map(u =>
      `<button class="snf-mob-use-tab${u.id===item.id?" active":""}" type="button" data-m-use-id="${u.id}">${u.label}</button>`
    ).join("");
    if (useImg) { useImg.src = item.image; useImg.alt = item.kicker + " — LevelUp"; }
    if (useKicker) useKicker.textContent = item.kicker;
    if (useTitle) useTitle.textContent = item.title;
    if (useText) useText.textContent = item.text;
    if (useBenefits) useBenefits.innerHTML = item.benefits.map(b =>
      `<div class="snf-mob-use-benefit">${b}</div>`).join("");
  }

  if (navWrap) {
    setUseCase("rows");
    navWrap.addEventListener("click", e => {
      const btn = e.target.closest("[data-m-use-id]");
      if (btn) setUseCase(btn.dataset.mUseId);
    });
  }

  /* ── QTY CONTROLS ─────────────────────────────────── */
  let qty = 1;
  const qtyInput = root.querySelector("[data-m-qty]");
  const buyNow = root.querySelector("[data-m-buynow]");
  function setQty(n) {
    qty = Math.max(1, Math.floor(isFinite(n) ? n : 1));
    if (qtyInput) qtyInput.value = qty;
    if (buyNow) buyNow.href = `/cart/{{ current_variant.id }}:${qty}`;
  }
  root.querySelector("[data-m-qty-inc]")?.addEventListener("click", () => setQty(qty + 1));
  root.querySelector("[data-m-qty-dec]")?.addEventListener("click", () => setQty(qty - 1));
  qtyInput?.addEventListener("change", () => setQty(parseInt(qtyInput.value)));

  /* ── STICKY BAR ───────────────────────────────────── */
  const sticky = root.querySelector("[data-m-sticky]");
  const buyBox = root.querySelector("#snf-m-buy-{{ section.id }}");
  if (sticky && buyBox) {
    const io = new IntersectionObserver(([e]) => {
      sticky.classList.toggle("show", !e.isIntersecting);
    }, { threshold: 0 });
    io.observe(buyBox);
  }

  /* ── FADE-UP REVEALS ──────────────────────────────── */
  const fadeEls = [...root.querySelectorAll(".fade-up")];
  if ("IntersectionObserver" in window) {
    const fadeIO = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("in"); fadeIO.unobserve(e.target); } });
    }, { threshold: 0.08 });
    fadeEls.forEach(el => fadeIO.observe(el));
  } else {
    fadeEls.forEach(el => el.classList.add("in"));
  }
})();
</script>
</div>

