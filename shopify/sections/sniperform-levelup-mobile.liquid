{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign media_hero      = product.featured_media | default: product.media.first
  assign media_lifestyle = product.media[1] | default: media_hero
  assign media_detail    = product.media[2] | default: media_lifestyle
  assign media_setup     = product.media[3] | default: media_detail
%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<div id="snf-mob-{{ section.id }}" class="snf-mob">
<style>
/* ─── TOKENS ─────────────────────────────────────────── */
.snf-mob{
  --ink:#0c1219;
  --ink2:#374552;
  --slate:#6b7785;
  --mint:#00c4b3;
  --mint-d:#006c69;
  --mint-s:#edfaf8;
  --line:rgba(12,18,25,.08);
  --line-m:rgba(12,18,25,.13);
  --white:#fff;
  --bg:#f8fafa;
  --dark:#111820;
  --dark2:#1c2530;
  --r:16px;
  --r-sm:10px;
  --r-xs:8px;
  --ease:cubic-bezier(.22,.8,.18,1);
  font-family:"Montserrat",sans-serif;
  color:var(--ink);
  background:var(--bg);
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}
.snf-mob *{box-sizing:border-box;margin:0;padding:0}
.snf-mob a{color:inherit;text-decoration:none}
.snf-mob button,
.snf-mob input{font:inherit;outline:none}
.snf-mob img,
.snf-mob video{display:block;max-width:100%}
.snf-mob ul,
.snf-mob ol{list-style:none}

/* ─── UTILITIES ─────────────────────────────────────── */
.snf-mob .mono{font-family:"IBM Plex Mono",monospace;letter-spacing:.14em;text-transform:uppercase}
.snf-mob .tag{display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border:1px solid var(--line-m);border-radius:999px;background:var(--white);font-size:11px;font-weight:700;color:var(--ink2)}
.snf-mob .tag-mint{border-color:rgba(0,196,179,.3);background:var(--mint-s);color:var(--mint-d)}
.snf-mob .tag-mint::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--mint);flex-shrink:0}
.snf-mob .px{padding-left:16px;padding-right:16px}
.snf-mob .divider{height:1px;background:var(--line)}
.snf-mob .section{padding:28px 0}

/* ─── ANNOUNCEMENT ───────────────────────────────────── */
.snf-mob-announce{
  overflow:hidden;
  height:36px;
  display:flex;
  align-items:center;
  background:var(--white);
  border-bottom:1px solid var(--line);
}
.snf-mob-announce-track{
  display:flex;
  gap:0;
  white-space:nowrap;
  animation:snfMarquee 28s linear infinite;
  will-change:transform;
}
.snf-mob-announce-track span{
  display:inline-flex;
  align-items:center;
  gap:20px;
  padding:0 32px;
  font-size:10.5px;
  font-weight:700;
  color:var(--ink2);
  letter-spacing:.12em;
  text-transform:uppercase;
}
.snf-mob-announce-track span::after{
  content:"";
  width:4px;
  height:4px;
  border-radius:50%;
  background:var(--mint);
  flex-shrink:0;
}
@keyframes snfMarquee{
  from{transform:translateX(0)}
  to{transform:translateX(-50%)}
}

/* ─── IMAGE CAROUSEL ─────────────────────────────────── */
.snf-mob-gallery{
  position:relative;
  background:var(--white);
  border-bottom:1px solid var(--line);
  user-select:none;
  -webkit-user-select:none;
}
.snf-mob-gallery-track{
  display:flex;
  overflow-x:scroll;
  scroll-snap-type:x mandatory;
  scroll-behavior:smooth;
  -webkit-overflow-scrolling:touch;
  scrollbar-width:none;
}
.snf-mob-gallery-track::-webkit-scrollbar{display:none}
.snf-mob-gallery-slide{
  flex:0 0 100%;
  scroll-snap-align:start;
  aspect-ratio:1 / 1;
  overflow:hidden;
  background:var(--mint-s);
}
.snf-mob-gallery-slide img{
  width:100%;
  height:100%;
  object-fit:cover;
}
.snf-mob-gallery-dots{
  position:absolute;
  bottom:12px;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  gap:5px;
  z-index:2;
}
.snf-mob-gallery-dots span{
  width:5px;
  height:5px;
  border-radius:50%;
  background:rgba(12,18,25,.22);
  transition:width .2s var(--ease), background .2s var(--ease);
}
.snf-mob-gallery-dots span.active{
  width:18px;
  border-radius:3px;
  background:var(--ink);
}
.snf-mob-gallery-badge{
  position:absolute;
  top:12px;
  right:12px;
  padding:6px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.92);
  border:1px solid var(--line-m);
  backdrop-filter:blur(8px);
  font-size:10px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.1em;
  text-transform:uppercase;
}

/* ─── PRODUCT HEAD ───────────────────────────────────── */
.snf-mob-head{
  padding:18px 16px 0;
  background:var(--white);
}
.snf-mob-head-brand{
  font-size:10.5px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.18em;
  text-transform:uppercase;
}
.snf-mob-head h1{
  margin-top:6px;
  font-size:26px;
  line-height:.95;
  letter-spacing:-.05em;
  font-weight:900;
  color:var(--ink);
}
.snf-mob-head-meta{
  display:flex;
  align-items:center;
  gap:10px;
  margin-top:10px;
}
.snf-mob-stars{
  display:flex;
  align-items:center;
  gap:3px;
  color:var(--mint-d);
  font-size:13px;
  letter-spacing:.1em;
}
.snf-mob-review-count{
  font-size:12px;
  font-weight:700;
  color:var(--slate);
}
.snf-mob-head-price{
  display:flex;
  align-items:center;
  gap:10px;
  margin-top:12px;
  padding-bottom:18px;
}
.snf-mob-price{
  font-size:32px;
  font-weight:900;
  letter-spacing:-.06em;
  line-height:1;
  color:var(--ink);
}
.snf-mob-price-compare{
  font-size:16px;
  font-weight:600;
  color:var(--slate);
  text-decoration:line-through;
}
.snf-mob-price-save{
  padding:3px 8px;
  border-radius:6px;
  background:var(--mint-s);
  border:1px solid rgba(0,196,179,.25);
  font-size:11px;
  font-weight:800;
  color:var(--mint-d);
}

/* ─── OFFER CAPSULE ──────────────────────────────────── */
.snf-mob-offer{
  margin:0 16px;
  padding:12px 14px;
  border:1px solid rgba(0,196,179,.28);
  border-radius:var(--r);
  background:var(--mint-s);
  display:flex;
  gap:10px;
  align-items:flex-start;
}
.snf-mob-offer-icon{
  flex-shrink:0;
  width:34px;
  height:34px;
  border-radius:10px;
  background:linear-gradient(135deg,var(--mint),var(--mint-d));
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:16px;
}
.snf-mob-offer-text strong{
  display:block;
  font-size:12.5px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.04em;
  text-transform:uppercase;
}
.snf-mob-offer-text p{
  margin-top:3px;
  font-size:12px;
  line-height:1.58;
  color:var(--ink2);
}

/* ─── BUY BOX ────────────────────────────────────────── */
.snf-mob-buybox{
  padding:16px;
  background:var(--white);
}
.snf-mob-qty-row{
  display:grid;
  grid-template-columns:112px 1fr;
  gap:10px;
}
.snf-mob-qty{
  display:grid;
  grid-template-columns:36px 1fr 36px;
  height:50px;
  border:1px solid var(--line-m);
  border-radius:var(--r-sm);
  overflow:hidden;
  background:var(--bg);
}
.snf-mob-qty button{
  border:0;
  background:transparent;
  color:var(--ink);
  font-size:20px;
  line-height:1;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  touch-action:manipulation;
}
.snf-mob-qty input{
  border:0;
  background:transparent;
  color:var(--ink);
  text-align:center;
  font-size:15px;
  font-weight:800;
  -moz-appearance:textfield;
  width:100%;
}
.snf-mob-qty input::-webkit-outer-spin-button,
.snf-mob-qty input::-webkit-inner-spin-button{-webkit-appearance:none}
.snf-mob-atc{
  height:50px;
  border:0;
  border-radius:var(--r-sm);
  background:linear-gradient(135deg,var(--mint) 0%,var(--mint-d) 100%);
  color:#fff;
  font-size:14.5px;
  font-weight:800;
  letter-spacing:.02em;
  cursor:pointer;
  width:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  touch-action:manipulation;
  transition:opacity .18s,transform .18s;
  box-shadow:0 8px 24px rgba(0,107,105,.22);
}
.snf-mob-atc:active{opacity:.86;transform:scale(.98)}
.snf-mob-atc[disabled]{opacity:.55;cursor:not-allowed}
.snf-mob-buynow{
  margin-top:10px;
  height:48px;
  width:100%;
  border:1px solid var(--line-m);
  border-radius:var(--r-sm);
  background:var(--white);
  color:var(--ink);
  font-size:14px;
  font-weight:700;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  touch-action:manipulation;
  transition:background .18s,border-color .18s;
}
.snf-mob-buynow:active{background:var(--bg)}
.snf-mob-buy-note{
  margin-top:10px;
  font-size:11px;
  color:var(--slate);
  text-align:center;
  line-height:1.55;
  font-weight:600;
}

/* ─── TRUST BAR ──────────────────────────────────────── */
.snf-mob-trust{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
  background:var(--white);
}
.snf-mob-trust-item{
  padding:14px 8px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:6px;
  text-align:center;
  border-right:1px solid var(--line);
}
.snf-mob-trust-item:last-child{border-right:0}
.snf-mob-trust-icon{
  font-size:19px;
  line-height:1;
}
.snf-mob-trust-label{
  font-size:10px;
  font-weight:800;
  color:var(--ink2);
  letter-spacing:.04em;
  line-height:1.4;
}

/* ─── BENEFITS ───────────────────────────────────────── */
.snf-mob-benefits{
  padding:24px 16px;
  background:var(--white);
}
.snf-mob-benefits-head{
  font-size:19px;
  font-weight:900;
  letter-spacing:-.04em;
  line-height:1.12;
  color:var(--ink);
  margin-bottom:16px;
}
.snf-mob-benefit-item{
  display:flex;
  gap:13px;
  align-items:flex-start;
  padding:14px 0;
  border-bottom:1px solid var(--line);
}
.snf-mob-benefit-item:last-child{border-bottom:0}
.snf-mob-benefit-num{
  flex-shrink:0;
  width:26px;
  height:26px;
  border-radius:8px;
  background:var(--ink);
  color:#fff;
  font-size:11px;
  font-weight:900;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-top:1px;
}
.snf-mob-benefit-copy strong{
  display:block;
  font-size:14.5px;
  font-weight:800;
  line-height:1.25;
  letter-spacing:-.02em;
}
.snf-mob-benefit-copy p{
  margin-top:4px;
  font-size:13px;
  line-height:1.68;
  color:var(--slate);
}

/* ─── STATS STRIP ────────────────────────────────────── */
.snf-mob-stats{
  display:grid;
  grid-template-columns:1fr 1fr;
  border:1px solid var(--line);
  border-radius:var(--r);
  overflow:hidden;
  margin:0 16px 24px;
  background:var(--white);
}
.snf-mob-stat{
  padding:16px 14px;
  border-right:1px solid var(--line);
  border-bottom:1px solid var(--line);
}
.snf-mob-stat:nth-child(2n){border-right:0}
.snf-mob-stat:nth-child(n+3){border-bottom:0}
.snf-mob-stat strong{
  display:block;
  font-size:28px;
  font-weight:900;
  letter-spacing:-.07em;
  line-height:.95;
  color:var(--ink);
}
.snf-mob-stat span{
  display:block;
  margin-top:5px;
  font-size:11px;
  font-weight:700;
  color:var(--slate);
  letter-spacing:.06em;
  text-transform:uppercase;
  line-height:1.4;
}

/* ─── PROOF VIDEO ────────────────────────────────────── */
.snf-mob-proof-vid{
  padding:0 16px 24px;
}
.snf-mob-proof-vid-label{
  display:flex;
  align-items:center;
  gap:8px;
  margin-bottom:12px;
  font-size:10.5px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.14em;
  text-transform:uppercase;
}
.snf-mob-proof-vid-label::before{
  content:"";
  width:20px;
  height:1px;
  background:var(--mint);
}
.snf-mob-proof-vid-wrap{
  border-radius:var(--r);
  overflow:hidden;
  background:#0b151c;
  border:1px solid var(--line);
  box-shadow:0 8px 32px rgba(11,21,28,.1);
}
.snf-mob-proof-vid-wrap video{
  width:100%;
  aspect-ratio:16/9;
  object-fit:cover;
  display:block;
}
.snf-mob-proof-quote{
  margin-top:14px;
  padding:14px;
  border:1px solid var(--line);
  border-radius:var(--r-sm);
  background:var(--white);
}
.snf-mob-proof-quote blockquote{
  font-size:14px;
  font-weight:700;
  line-height:1.62;
  color:var(--ink);
}
.snf-mob-proof-quote cite{
  display:block;
  margin-top:8px;
  font-size:10.5px;
  font-weight:800;
  color:var(--mint-d);
  font-style:normal;
  letter-spacing:.12em;
  text-transform:uppercase;
}

/* ─── REVIEW CARDS ───────────────────────────────────── */
.snf-mob-reviews-head{
  padding:0 16px 12px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}
.snf-mob-reviews-head h2{
  font-size:18px;
  font-weight:900;
  letter-spacing:-.04em;
}
.snf-mob-reviews-scroll{
  display:flex;
  gap:10px;
  padding:0 16px 24px;
  overflow-x:auto;
  scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling:touch;
  scrollbar-width:none;
}
.snf-mob-reviews-scroll::-webkit-scrollbar{display:none}
.snf-mob-review-card{
  flex:0 0 268px;
  scroll-snap-align:start;
  padding:14px;
  border:1px solid var(--line-m);
  border-radius:var(--r);
  background:var(--white);
}
.snf-mob-review-card .snf-mob-stars{margin-bottom:8px}
.snf-mob-review-card blockquote{
  font-size:13px;
  line-height:1.68;
  color:var(--ink2);
  font-weight:600;
}
.snf-mob-review-card cite{
  display:block;
  margin-top:10px;
  font-size:10.5px;
  font-weight:800;
  color:var(--slate);
  font-style:normal;
  letter-spacing:.1em;
  text-transform:uppercase;
}
.snf-mob-review-card .snf-mob-review-badge{
  display:inline-flex;
  align-items:center;
  gap:5px;
  margin-top:8px;
  padding:3px 8px;
  border-radius:6px;
  background:var(--mint-s);
  font-size:10px;
  font-weight:700;
  color:var(--mint-d);
}

/* ─── USE CASES ──────────────────────────────────────── */
.snf-mob-use{
  padding:0 0 24px;
  background:var(--white);
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
}
.snf-mob-use-head{
  padding:20px 16px 14px;
}
.snf-mob-use-eyebrow{
  font-size:10.5px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.16em;
  text-transform:uppercase;
  margin-bottom:6px;
}
.snf-mob-use-head h2{
  font-size:20px;
  font-weight:900;
  letter-spacing:-.04em;
  line-height:1.1;
}
.snf-mob-use-nav{
  display:flex;
  gap:8px;
  padding:0 16px;
  overflow-x:auto;
  scrollbar-width:none;
  -webkit-overflow-scrolling:touch;
  padding-bottom:2px;
}
.snf-mob-use-nav::-webkit-scrollbar{display:none}
.snf-mob-use-tab{
  flex-shrink:0;
  padding:8px 14px;
  border:1px solid var(--line-m);
  border-radius:999px;
  background:var(--white);
  font-size:12.5px;
  font-weight:700;
  color:var(--ink2);
  cursor:pointer;
  touch-action:manipulation;
  transition:background .18s,border-color .18s,color .18s;
}
.snf-mob-use-tab.active{
  background:var(--ink);
  border-color:var(--ink);
  color:#fff;
}
.snf-mob-use-panel{
  margin:14px 16px 0;
}
.snf-mob-use-img{
  border-radius:var(--r);
  overflow:hidden;
  aspect-ratio:4/3;
  background:var(--bg);
  border:1px solid var(--line);
}
.snf-mob-use-img img{
  width:100%;
  height:100%;
  object-fit:cover;
}
.snf-mob-use-copy{
  margin-top:14px;
}
.snf-mob-use-kicker{
  font-size:10.5px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.16em;
  text-transform:uppercase;
}
.snf-mob-use-title{
  margin-top:6px;
  font-size:18px;
  font-weight:900;
  letter-spacing:-.04em;
  line-height:1.1;
}
.snf-mob-use-text{
  margin-top:8px;
  font-size:13px;
  line-height:1.72;
  color:var(--slate);
}
.snf-mob-use-benefits{
  margin-top:12px;
  display:grid;
  gap:0;
  border-top:1px solid var(--line);
}
.snf-mob-use-benefit{
  padding:10px 0 10px 16px;
  border-bottom:1px solid var(--line);
  font-size:12.5px;
  line-height:1.6;
  color:var(--ink2);
  font-weight:600;
  position:relative;
}
.snf-mob-use-benefit:last-child{border-bottom:0}
.snf-mob-use-benefit::before{
  content:"";
  position:absolute;
  left:0;
  top:18px;
  width:6px;
  height:6px;
  border-radius:50%;
  background:var(--mint);
}

/* ─── SPECS ACCORDION ────────────────────────────────── */
.snf-mob-specs{
  padding:24px 0;
  background:var(--white);
  border-top:1px solid var(--line);
}
.snf-mob-specs-head{
  padding:0 16px 16px;
}
.snf-mob-specs-eyebrow{
  font-size:10.5px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.16em;
  text-transform:uppercase;
  margin-bottom:6px;
}
.snf-mob-specs-head h2{
  font-size:20px;
  font-weight:900;
  letter-spacing:-.04em;
  line-height:1.1;
}
.snf-mob-spec-row{
  border-top:1px solid var(--line);
}
.snf-mob-spec-row:last-child{border-bottom:1px solid var(--line)}
.snf-mob-spec-summary{
  list-style:none;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:14px 16px;
  cursor:pointer;
  -webkit-tap-highlight-color:transparent;
}
.snf-mob-spec-summary::-webkit-details-marker{display:none}
.snf-mob-spec-label{
  font-size:10.5px;
  font-weight:800;
  color:var(--mint-d);
  letter-spacing:.14em;
  text-transform:uppercase;
}
.snf-mob-spec-title{
  display:block;
  margin-top:2px;
  font-size:14px;
  font-weight:800;
  letter-spacing:-.02em;
  color:var(--ink);
}
.snf-mob-spec-chevron{
  flex-shrink:0;
  width:22px;
  height:22px;
  border:1px solid var(--line-m);
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--slate);
  font-size:14px;
  font-weight:700;
  transition:transform .22s var(--ease);
}
details[open] .snf-mob-spec-chevron{transform:rotate(45deg)}
.snf-mob-spec-body{
  padding:0 16px 16px;
  font-size:13px;
  line-height:1.74;
  color:var(--slate);
}

/* ─── COMPARISON ─────────────────────────────────────── */
.snf-mob-compare{
  padding:24px 16px;
}
