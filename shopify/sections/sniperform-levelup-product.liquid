{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign media_hero = product.featured_media | default: product.media.first
  assign media_lifestyle = product.media[1] | default: media_hero
  assign media_detail = product.media[2] | default: media_lifestyle
  assign media_setup = product.media[3] | default: media_detail
%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<section id="snf-levelup-{{ section.id }}" class="snf-levelup">
  <style>
    .snf-levelup{
      --mint:#00c4b3;
      --mint-deep:#006c69;
      --mint-soft:#eaf8f5;
      --ink:#1f262e;
      --ink-soft:#33404b;
      --slate:#66717c;
      --line:rgba(31,38,46,.12);
      --line-strong:rgba(31,38,46,.2);
      --paper:#f4f9f8;
      --white:#fff;
      --shadow:0 18px 48px rgba(14,24,32,.08);
      --shadow-dark:0 30px 70px rgba(10,20,28,.22);
      --radius-xl:32px;
      --radius-lg:24px;
      --ease:cubic-bezier(.22,.8,.18,1);
      color:var(--ink);
      font-family:"Montserrat",sans-serif;
      background:linear-gradient(180deg,#f7fbfb 0%, #ffffff 14%, #ffffff 100%);
      overflow:hidden;
      position:relative;
      isolation:isolate;
    }
    .snf-levelup::before{
      content:"";
      position:absolute;
      inset:0;
      z-index:-1;
      background:
        radial-gradient(circle at 12% 0%, rgba(0,196,179,.12), transparent 24%),
        radial-gradient(circle at 92% 10%, rgba(0,107,105,.08), transparent 16%),
        linear-gradient(180deg,#f7fbfb 0%, #ffffff 40%, #ffffff 100%);
    }
    .snf-levelup *{box-sizing:border-box}
    .snf-levelup a{color:inherit;text-decoration:none}
    .snf-levelup button,
    .snf-levelup input{font:inherit}
    .snf-levelup img,
    .snf-levelup video{display:block;max-width:100%}
    .snf-levelup .wrap{width:min(1220px,calc(100% - 28px));margin:0 auto}
    .snf-levelup .mono{font-family:"IBM Plex Mono",monospace;letter-spacing:.16em;text-transform:uppercase}
    .snf-levelup .eyebrow{display:inline-flex;align-items:center;gap:12px;color:var(--mint-deep);font-size:12px;font-weight:600}
    .snf-levelup .eyebrow::before{content:"";width:30px;height:1px;background:rgba(0,107,105,.35)}
    .snf-levelup .section-head{max-width:720px}
    .snf-levelup .section-head h2{margin-top:18px;font-size:clamp(34px,4.4vw,58px);line-height:.94;letter-spacing:-.06em;font-weight:800}
    .snf-levelup .section-head p{margin-top:16px;color:var(--slate);font-size:16px;line-height:1.78}
    .snf-levelup .button,
    .snf-levelup .button-ghost,
    .snf-levelup .button-dark{display:inline-flex;align-items:center;justify-content:center;min-height:54px;padding:14px 22px;border-radius:999px;font-weight:800;transition:transform .24s var(--ease), background .24s var(--ease), border-color .24s var(--ease), color .24s var(--ease)}
    .snf-levelup .button{color:#fff;background:linear-gradient(135deg,var(--mint),var(--mint-deep));box-shadow:0 14px 28px rgba(0,107,105,.18)}
    .snf-levelup .button-dark{color:#fff;background:var(--ink)}
    .snf-levelup .button-ghost{border:1px solid var(--line-strong);color:var(--ink);background:transparent}
    .snf-levelup .button:hover,
    .snf-levelup .button-dark:hover,
    .snf-levelup .button-ghost:hover{transform:translateY(-2px)}
    .snf-levelup .pill{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.78);color:var(--ink-soft);font-size:12px;font-weight:700}
    .snf-levelup .pill::before{content:"";width:8px;height:8px;border-radius:999px;background:linear-gradient(135deg,var(--mint),var(--mint-deep))}

    .snf-levelup .announcement{border-bottom:1px solid rgba(255,255,255,.6);background:linear-gradient(90deg,#e8fffb 0%, #f8fefd 100%)}
    .snf-levelup .announcement .wrap{min-height:42px;display:flex;align-items:center;justify-content:center;gap:18px;flex-wrap:wrap;color:var(--ink-soft);font-size:11px;font-weight:700}
    .snf-levelup .announcement span{display:inline-flex;align-items:center;gap:10px}
    .snf-levelup .announcement span::before{content:"";width:6px;height:6px;border-radius:999px;background:var(--mint)}

    .snf-levelup .hero{padding:44px 0 28px}
    .snf-levelup .hero-shell{display:grid;grid-template-columns:minmax(0,.9fr) minmax(0,1.1fr);gap:42px;align-items:start}
    .snf-levelup .hero-copy{padding-top:24px}
    .snf-levelup .hero-copy h1{margin-top:18px;font-size:clamp(54px,8vw,96px);line-height:.88;letter-spacing:-.08em;font-weight:900;max-width:9.5ch}
    .snf-levelup .hero-copy .accent{color:var(--mint-deep)}
    .snf-levelup .hero-copy p{max-width:620px;margin-top:18px;color:var(--slate);font-size:17px;line-height:1.82}
    .snf-levelup .hero-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:30px}
    .snf-levelup .hero-trust{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
    .snf-levelup .hero-proofline{display:flex;align-items:center;gap:14px;margin-top:22px;color:var(--ink-soft);font-size:13px;line-height:1.6;font-weight:700;max-width:570px}
    .snf-levelup .hero-stars{color:var(--mint-deep);letter-spacing:.18em;font-size:14px}
    .snf-levelup .hero-right{display:grid;gap:18px}

    .snf-levelup .hero-stage{position:relative;min-height:580px;padding:28px;overflow:hidden;border:1px solid var(--line);border-radius:var(--radius-xl);background:linear-gradient(180deg,#f4fffd 0%, #e7f5f2 100%);box-shadow:var(--shadow)}
    .snf-levelup .hero-stage::before{content:"";position:absolute;left:-20px;bottom:20px;width:240px;height:240px;border-radius:50%;background:radial-gradient(circle, rgba(0,196,179,.14), transparent 72%)}
    .snf-levelup .hero-stage::after{content:"";position:absolute;top:32px;right:32px;width:320px;height:320px;border-radius:50%;border:1px solid rgba(0,107,105,.14);background:radial-gradient(circle, rgba(255,255,255,.72) 0%, rgba(255,255,255,.12) 50%, transparent 72%)}
    .snf-levelup .hero-stage-top{position:relative;z-index:1;display:grid;grid-template-columns:minmax(0,1fr) auto;gap:20px;align-items:start}
    .snf-levelup .hero-stage-top strong{display:block;font-size:22px;line-height:1.12;letter-spacing:-.04em;max-width:13ch}
    .snf-levelup .hero-stage-top p{margin-top:8px;color:var(--slate);font-size:14px;line-height:1.7;max-width:34ch}
    .snf-levelup .stage-chip{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;background:rgba(255,255,255,.78);border:1px solid rgba(255,255,255,.95);color:var(--ink-soft);font-size:12px;font-weight:700}
    .snf-levelup .stage-chip::before{content:"";width:8px;height:8px;border-radius:999px;background:var(--mint)}
    .snf-levelup .hero-stage-image{position:relative;z-index:1;width:min(520px,92%);margin:38px auto 32px}
    .snf-levelup .hero-stage-image img{width:100%;height:auto;filter:drop-shadow(0 30px 40px rgba(17,36,40,.14))}
    .snf-levelup .hero-stage-rail{position:relative;z-index:1;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px;padding-top:22px;border-top:1px solid rgba(31,38,46,.1)}
    .snf-levelup .hero-stage-rail div{padding-right:18px;border-right:1px solid rgba(31,38,46,.08)}
    .snf-levelup .hero-stage-rail div:last-child{padding-right:0;border-right:0}
    .snf-levelup .hero-stage-rail strong{display:block;font-size:18px;line-height:1.1;letter-spacing:-.04em}
    .snf-levelup .hero-stage-rail span{display:block;margin-top:8px;color:var(--slate);font-size:13px;line-height:1.6}

    .snf-levelup .buy-card{padding:26px;border-radius:var(--radius-xl);background:linear-gradient(180deg,#222c34 0%, #151b21 100%);color:#fff;border:1px solid rgba(255,255,255,.08);box-shadow:var(--shadow-dark)}
    .snf-levelup .buy-kicker{display:flex;align-items:center;justify-content:space-between;gap:12px;color:rgba(255,255,255,.72);font-size:11px}
    .snf-levelup .buy-kicker span:last-child{color:#91efe4;font-weight:700}
    .snf-levelup .buy-card h2{margin-top:16px;font-size:32px;line-height:.94;letter-spacing:-.06em;max-width:12ch}
    .snf-levelup .buy-card p{max-width:56ch;margin-top:14px;color:rgba(255,255,255,.78);font-size:14px;line-height:1.75}
    .snf-levelup .price-row{display:flex;align-items:end;justify-content:space-between;gap:16px;margin-top:20px}
    .snf-levelup .price-row strong{font-size:42px;line-height:.9;letter-spacing:-.06em}
    .snf-levelup .price-row span{max-width:170px;color:#97fff0;font-size:12px;line-height:1.5;font-weight:700;text-align:right}
    .snf-levelup .buy-facts{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-top:18px;padding:16px 0;border-top:1px solid rgba(255,255,255,.08);border-bottom:1px solid rgba(255,255,255,.08)}
    .snf-levelup .buy-facts span{display:block;color:rgba(255,255,255,.72);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase}
    .snf-levelup .buy-facts strong{display:block;margin-top:6px;font-size:16px;line-height:1.2;letter-spacing:-.03em}
    .snf-levelup .offer{margin-top:16px;padding:16px 18px;border-radius:22px;background:rgba(0,196,179,.12);border:1px solid rgba(145,239,228,.18)}
    .snf-levelup .offer strong{display:block;color:#fff;font-size:13px;letter-spacing:.12em;text-transform:uppercase}
    .snf-levelup .offer p{margin-top:6px;color:#dffef9;font-size:12px;line-height:1.6}
    .snf-levelup .buy-bullets{display:grid;gap:12px;margin-top:18px;padding:0}
    .snf-levelup .buy-bullets li{list-style:none;display:flex;gap:10px;color:#fff;font-size:14px;line-height:1.62}
    .snf-levelup .buy-bullets li::before{content:"";flex:0 0 8px;width:8px;height:8px;border-radius:999px;margin-top:7px;background:#8df0e4}
    .snf-levelup .buy-proof{margin-top:18px;padding-top:18px;border-top:1px solid rgba(255,255,255,.08)}
    .snf-levelup .buy-proof blockquote{font-size:15px;line-height:1.68;font-weight:600}
    .snf-levelup .buy-proof cite{display:block;margin-top:10px;color:rgba(255,255,255,.64);font-size:12px;font-style:normal;text-transform:uppercase;letter-spacing:.12em}
    .snf-levelup .checkout{display:grid;gap:12px;margin-top:22px}
    .snf-levelup .qty{display:grid;grid-template-columns:48px 1fr 48px;min-height:54px;border-radius:999px;overflow:hidden;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.05)}
    .snf-levelup .qty button{border:0;background:transparent;color:#fff;font-size:24px;cursor:pointer}
    .snf-levelup .qty input{border:0;background:transparent;color:#fff;text-align:center;outline:none;font-size:16px;font-weight:700}
    .snf-levelup .cart-form,
    .snf-levelup .buy-now-wrap{width:100%}
    .snf-levelup .cart-form button,
    .snf-levelup .buy-now{width:100%}
    .snf-levelup .cart-form button{border:0;cursor:pointer}
    .snf-levelup .buy-now{border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.05);color:#fff}
    .snf-levelup .buy-note{color:rgba(255,255,255,.6);font-size:11px;line-height:1.55;text-align:center}

    .snf-levelup .metrics{padding:8px 0 32px}
    .snf-levelup .metric-strip{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .snf-levelup .metric-strip li{list-style:none;padding:20px 14px 18px;border-right:1px solid var(--line)}
    .snf-levelup .metric-strip li:last-child{border-right:0}
    .snf-levelup .metric-strip strong{display:block;font-size:30px;line-height:.9;letter-spacing:-.06em}
    .snf-levelup .metric-strip span{display:block;margin-top:8px;color:var(--slate);font-size:12px;line-height:1.55;text-transform:uppercase;letter-spacing:.08em;font-weight:700}

    .snf-levelup .why{padding:52px 0 24px}
    .snf-levelup .why-shell{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:44px;align-items:start}
    .snf-levelup .why-media figure{overflow:hidden;border-radius:var(--radius-xl);background:var(--paper);box-shadow:var(--shadow)}
    .snf-levelup .why-media img{width:100%;aspect-ratio:4 / 5;object-fit:cover}
    .snf-levelup .why-caption{margin-top:18px}
    .snf-levelup .why-caption strong{display:block;font-size:28px;line-height:1.04;letter-spacing:-.05em;max-width:15ch}
    .snf-levelup .why-caption p{max-width:52ch;margin-top:10px;color:var(--slate);font-size:15px;line-height:1.74}
    .snf-levelup .why-thumbs{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;margin-top:18px}
    .snf-levelup .why-thumb{overflow:hidden;border-radius:var(--radius-lg);background:var(--white);border:1px solid var(--line)}
    .snf-levelup .why-thumb img{width:100%;aspect-ratio:4 / 3;object-fit:cover}
    .snf-levelup .why-thumb span{display:block;padding:14px 14px 16px;font-size:14px;line-height:1.5;font-weight:700}
    .snf-levelup .why-content .section-head{margin-bottom:28px}
    .snf-levelup .why-list{border-top:1px solid var(--line)}
    .snf-levelup .feature-row{display:grid;grid-template-columns:150px minmax(0,1fr);gap:20px;padding:24px 0;border-bottom:1px solid var(--line)}
    .snf-levelup .feature-row span{color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    .snf-levelup .feature-row strong{display:block;font-size:24px;line-height:1.05;letter-spacing:-.05em}
    .snf-levelup .feature-row p{margin-top:10px;color:var(--slate);font-size:15px;line-height:1.78}

    .snf-levelup .use-cases{padding:52px 0 26px}
    .snf-levelup .use-shell{margin-top:28px}
    .snf-levelup .use-nav{display:flex;flex-wrap:wrap;gap:10px}
    .snf-levelup .use-tab{padding:12px 16px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.78);text-align:left;cursor:pointer;transition:background .24s var(--ease), border-color .24s var(--ease), color .24s var(--ease)}
    .snf-levelup .use-tab.active{background:var(--ink);border-color:var(--ink);color:#fff}
    .snf-levelup .use-tab small{display:block;color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    .snf-levelup .use-tab.active small{color:#9df1e7}
    .snf-levelup .use-tab strong{display:block;margin-top:6px;font-size:14px;line-height:1.35;letter-spacing:-.02em}
    .snf-levelup .use-tab span{display:none}
    .snf-levelup .use-panel{display:grid;grid-template-columns:minmax(0,.9fr) minmax(0,1.1fr);gap:30px;align-items:center;margin-top:22px;padding-top:24px;border-top:1px solid var(--line)}
    .snf-levelup .use-image{min-height:500px;border-radius:var(--radius-xl);overflow:hidden;background:var(--paper);box-shadow:var(--shadow)}
    .snf-levelup .use-image img{width:100%;height:100%;object-fit:cover}
    .snf-levelup .use-copy small{color:var(--mint-deep);font-size:12px;font-weight:800;letter-spacing:.18em;text-transform:uppercase}
    .snf-levelup .use-copy h3{max-width:12ch;margin-top:18px;font-size:clamp(32px,3vw,48px);line-height:.95;letter-spacing:-.06em}
    .snf-levelup .use-copy p{max-width:56ch;margin-top:16px;color:var(--slate);font-size:15px;line-height:1.82}
    .snf-levelup .use-benefits{display:grid;gap:0;margin-top:20px;border-top:1px solid var(--line)}
    .snf-levelup .use-benefit{position:relative;padding:16px 0 16px 20px;border-bottom:1px solid var(--line);font-size:14px;line-height:1.7;color:var(--ink-soft);font-weight:600}
    .snf-levelup .use-benefit::before{content:"";position:absolute;left:0;top:25px;width:8px;height:8px;border-radius:999px;background:var(--mint)}

    .snf-levelup .engineering{padding:52px 0 26px}
    .snf-levelup .engineering-shell{display:grid;grid-template-columns:minmax(0,.96fr) minmax(0,1.04fr);gap:44px;align-items:start}
    .snf-levelup .engineering-media{display:grid;gap:16px}
    .snf-levelup .engineering-stage{overflow:hidden;border-radius:var(--radius-xl);background:var(--paper);box-shadow:var(--shadow)}
    .snf-levelup .engineering-stage img{width:100%;height:auto}
    .snf-levelup .engineering-content .section-head{margin-bottom:28px}
    .snf-levelup .spec-list{border-top:1px solid var(--line)}
    .snf-levelup .spec-row{display:grid;grid-template-columns:130px minmax(0,1fr);gap:24px;padding:22px 0;border-bottom:1px solid var(--line)}
    .snf-levelup .spec-row span{color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    .snf-levelup .spec-row strong{display:block;font-size:22px;line-height:1.08;letter-spacing:-.05em}
    .snf-levelup .spec-row p{margin-top:10px;color:var(--slate);font-size:14px;line-height:1.72}
    .snf-levelup .founder{margin-top:24px;padding-left:22px;border-left:3px solid var(--mint)}
    .snf-levelup .founder strong{display:block;font-size:28px;line-height:1.04;letter-spacing:-.05em}
    .snf-levelup .founder p{margin-top:12px;color:var(--slate);font-size:15px;line-height:1.82}
    .snf-levelup .founder blockquote{margin-top:16px;color:var(--ink);font-size:18px;line-height:1.68;font-weight:700}
    .snf-levelup .founder cite{display:block;margin-top:10px;color:var(--mint-deep);font-size:12px;font-style:normal;text-transform:uppercase;letter-spacing:.14em;font-weight:800}

    .snf-levelup .proof{padding:52px 0 26px}
    .snf-levelup .proof .section-head{margin-bottom:28px}
    .snf-levelup .proof-main{display:grid;grid-template-columns:minmax(0,.9fr) minmax(0,1.1fr);gap:32px;align-items:start;padding:26px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .snf-levelup .quote-copy blockquote{max-width:12ch;font-size:clamp(30px,3.6vw,46px);line-height:1.02;letter-spacing:-.06em;font-weight:800}
    .snf-levelup .quote-copy p{max-width:55ch;margin-top:16px;color:var(--slate);font-size:15px;line-height:1.82}
    .snf-levelup .quote-copy cite{display:block;margin-top:16px;color:var(--mint-deep);font-size:12px;font-style:normal;text-transform:uppercase;letter-spacing:.14em;font-weight:800}
    .snf-levelup .quote-media{overflow:hidden;border-radius:var(--radius-xl);background:#0e141a;box-shadow:var(--shadow)}
    .snf-levelup .quote-media video{width:100%;aspect-ratio:16 / 10;object-fit:cover;background:#0e141a}
    .snf-levelup .proof-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px;margin-top:24px}
    .snf-levelup .proof-item video{width:100%;aspect-ratio:4 / 5;object-fit:cover;border-radius:var(--radius-lg);background:#091114;box-shadow:var(--shadow)}
    .snf-levelup .proof-caption{margin-top:14px;padding-top:14px;border-top:1px solid var(--line)}
    .snf-levelup .proof-caption small{color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    .snf-levelup .proof-caption strong{display:block;margin-top:8px;font-size:20px;line-height:1.1;letter-spacing:-.04em}
    .snf-levelup .proof-caption p{margin-top:8px;color:var(--slate);font-size:14px;line-height:1.7}

    .snf-levelup .compare{padding:52px 0 24px}
    .snf-levelup .compare .section-head{margin-bottom:28px}
    .snf-levelup .compare-table{border-top:1px solid var(--line-strong);border-bottom:1px solid var(--line-strong)}
    .snf-levelup .compare-head,
    .snf-levelup .compare-row{display:grid;grid-template-columns:1.2fr .9fr .9fr;gap:18px;align-items:center}
    .snf-levelup .compare-head{padding:16px 0;color:var(--slate);font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.14em}
    .snf-levelup .compare-row{padding:20px 0;border-top:1px solid var(--line)}
    .snf-levelup .compare-row strong{font-size:16px;line-height:1.4}
    .snf-levelup .compare-row span{font-size:14px;line-height:1.7;color:var(--slate)}
    .snf-levelup .compare-row .yes{color:var(--ink);font-weight:700}
    .snf-levelup .compare-row .snf{color:var(--mint-deep);font-weight:800}

    .snf-levelup .faq{padding:52px 0 90px}
    .snf-levelup .faq-shell{display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:44px;align-items:start}
    .snf-levelup .faq .section-head{margin-bottom:28px}
    .snf-levelup .faq-list{border-top:1px solid var(--line)}
    .snf-levelup details{border-bottom:1px solid var(--line);padding:0;background:transparent}
