        </div>
      </div>

      <aside class="cta-card reveal">
        <span class="eyebrow mono">Final CTA</span>
        <h3>{{ section.settings.final_heading }}</h3>
        <p>{{ section.settings.final_text }}</p>
        <div class="cta-mini">
          <span>Free shaker auto-applied while stocks last</span>
          <span>30-day money-back guarantee</span>
          <span>Fits standard 28–32mm bars and dumbbells</span>
          <span>Fast checkout on the live Sniperform store</span>
        </div>
        <div class="cta-stack">
          <a class="button" href="#snf-buy-box-{{ section.id }}">Get LevelUp Grips</a>
          <a class="button-ghost" href="{{ product.url }}">Open product details</a>
        </div>
      </aside>
    </div>
  </div>

  <div class="sticky-dock" data-sticky-dock>
    <div class="sticky-inner">
      <div class="sticky-copy">
        <strong>{{ product.title }} / {{ current_variant.price | money }}</strong>
        <span>Patented level feedback, quick-lock fit, free shaker while stocks last.</span>
      </div>
      <a class="button" href="#snf-buy-box-{{ section.id }}">Buy now</a>
    </div>
  </div>

  <script>
    (() => {
      const root = document.getElementById("snf-levelup-{{ section.id }}");
      if (!root) return;

      const useCases = [
        {
          id: "rows",
          kicker: "Rows",
          label: "Rows",
          summary: "Grip harder. Keep the pull level.",
          title: "Rows reward the thicker handle and the level cue at the same time.",
          text: "On rows, LevelUp drives more grip demand while showing when the pull starts to twist or one side begins to dominate. It is one of the fastest lifts for making the product feel immediately useful.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A2557_square_crop_2000.webp?v=1769487620&width=1800",
          benefits: [
            "More squeeze through the hands, forearms and biceps from the first rep.",
            "A visible cue to stop the bar path drifting as fatigue builds.",
            "An easy first use case for serious back and arm work."
          ]
        },
        {
          id: "curls",
          kicker: "Curls",
          label: "Curls",
          summary: "Turn arm day into a harder contraction.",
          title: "Curls make the bigger-arm promise obvious.",
          text: "LevelUp makes curls feel harder through the grip immediately, which keeps the growth story simple. The level cue adds a layer of control so the pitch is not just bigger pump, but cleaner work through both arms.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A2480_square_crop_2000.webp?v=1769488611&width=1800",
          benefits: [
            "Supports the thick-grip arm-growth angle without changing the movement itself.",
            "Keeps one side from quietly taking over as the set gets messy.",
            "Makes the product feel instantly relevant for arm-day buyers."
          ]
        },
        {
          id: "presses",
          kicker: "Presses",
          label: "Presses",
          summary: "Spot drift before shoulders pay for it.",
          title: "Pressing is where the alignment cue starts to feel protective as well as powerful.",
          text: "Presses expose wrist and shoulder drift fast. The visible level cue helps the lifter correct sooner, which makes LevelUp feel like performance equipment with a real control benefit rather than just another grip accessory.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A3029_square_crop_2000.webp?v=1767933896&width=1800",
          benefits: [
            "Strengthens the connection between balanced reps and cleaner joint mechanics.",
            "Makes the patented feedback system feel serious, not decorative.",
            "Adds more grip demand without stripping the movement of control."
          ]
        },
        {
          id: "pulls",
          kicker: "Pulls",
          label: "Pulls",
          summary: "Make grip the limiter, not the afterthought.",
          title: "Heavy pulls turn grip strength into the feature, not the bottleneck.",
          text: "When the handle gets thicker, pulling movements become a real test of grip capacity. That expands LevelUp beyond arm-day novelty and into something advanced lifters can justify across multiple sessions each week.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A2747.png?v=1738733865&width=1400",
          benefits: [
            "Supports the hand-crushing grip strength angle from the live store.",
            "Shows the tool belongs in more than one exercise slot.",
            "Builds a more serious performance story for advanced lifters."
          ]
        }
      ];

      const tabWrap = root.querySelector("[data-use-tabs]");
      const useImage = root.querySelector("[data-use-image]");
      const useKicker = root.querySelector("[data-use-kicker]");
      const useTitle = root.querySelector("[data-use-title]");
      const useText = root.querySelector("[data-use-text]");
      const useBenefits = root.querySelector("[data-use-benefits]");
      const qtyDisplays = [...root.querySelectorAll("[data-qty-display]")];
      const qtyIncrease = [...root.querySelectorAll("[data-qty-increase]")];
      const qtyDecrease = [...root.querySelectorAll("[data-qty-decrease]")];
      const buyNowLinks = [...root.querySelectorAll("[data-buy-now]")];
      const stickyDock = root.querySelector("[data-sticky-dock]");
      const autoVideos = [...root.querySelectorAll("[data-auto-video]")];
      const proofSection = root.querySelector("#snf-proof-{{ section.id }}");
      let quantity = 1;

      function setUseCase(id){
        const item = useCases.find((entry) => entry.id === id) || useCases[0];
        tabWrap.innerHTML = useCases.map((entry) => `
          <button class="use-tab${entry.id === item.id ? " active" : ""}" type="button" data-use-id="${entry.id}">
            <small class="mono">${entry.label}</small>
            <strong>${entry.summary}</strong>
            <span>${entry.id === item.id ? "Selected" : "View"}</span>
          </button>
        `).join("");
        useImage.src = item.image;
        useImage.alt = `${item.label} use case with Sniperform LevelUp`;
        useKicker.textContent = item.kicker;
        useTitle.textContent = item.title;
        useText.textContent = item.text;
        useBenefits.innerHTML = item.benefits.map((benefit) => `<div class="use-benefit">${benefit}</div>`).join("");
      }

      function syncQuantity(next){
        quantity = Math.max(1, Number.isFinite(next) ? Math.floor(next) : 1);
        qtyDisplays.forEach((input) => { input.value = String(quantity); });
        buyNowLinks.forEach((link) => { link.href = `/cart/{{ current_variant.id }}:${quantity}`; });
      }

      function updateDock(){
        if (!stickyDock) return;
        const desktop = window.matchMedia("(min-width: 861px)").matches;
        const threshold = proofSection ? Math.max(1200, root.offsetTop + proofSection.offsetTop - 260) : 1200;
        stickyDock.classList.toggle("show", desktop && window.scrollY > threshold);
      }

      setUseCase("rows");
      syncQuantity(1);
      updateDock();

      tabWrap.addEventListener("click", (event) => {
        const button = event.target.closest("[data-use-id]");
        if (!button) return;
        setUseCase(button.dataset.useId);
      });

      qtyIncrease.forEach((button) => button.addEventListener("click", () => syncQuantity(quantity + 1)));
      qtyDecrease.forEach((button) => button.addEventListener("click", () => syncQuantity(quantity - 1)));
      qtyDisplays.forEach((input) => input.addEventListener("input", () => syncQuantity(Number(input.value))));

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const videoObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const video = entry.target;
          if (reducedMotion) {
            video.pause();
            return;
          }
          if (entry.isIntersecting) video.play().catch(() => {});
          else video.pause();
        });
      }, { threshold: 0.35 });
      autoVideos.forEach((video) => videoObserver.observe(video));

      window.addEventListener("scroll", updateDock, { passive: true });
      window.addEventListener("resize", updateDock);
    })();
  </script>
</section>

