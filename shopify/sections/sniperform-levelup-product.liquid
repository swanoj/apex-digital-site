      <div>
        <div class="section-head reveal">
          <span class="eyebrow mono">FAQ</span>
          <h2>Answer the last objections while the intent is still high.</h2>
          <p>These are the purchase questions repeated across the live store, the proof section, and the offer stack. Keeping them tight prevents the page from losing momentum this close to checkout.</p>
        </div>
        <div class="faq-list">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'faq' %}
                <details class="reveal"{% if forloop.first %} open{% endif %} {{ block.shopify_attributes }}>
                  <summary>{{ block.settings.question }}</summary>
                  <div class="faq-answer">{{ block.settings.answer }}</div>
                </details>
            {% endcase %}
          {% endfor %}
        </div>
      </div>

      <aside class="cta-card card-dark reveal">
        <span class="eyebrow mono" style="color:#8df0e4">Final CTA</span>
        <h3>{{ section.settings.final_heading }}</h3>
        <p>{{ section.settings.final_text }}</p>
        <div class="cta-mini">
          <span>Free shaker auto-applied while stocks last</span>
          <span>30-day money-back guarantee</span>
          <span>Fast checkout on the live Sniperform store</span>
          <span>Now shipping to the U.S.A</span>
        </div>
        <div class="cta-stack">
          <a class="button" href="#snf-buy-box-{{ section.id }}">Get LevelUp Grips</a>
          <a class="button-ghost" href="{{ product.url }}">Open product details</a>
        </div>
      </aside>
    </div>
  </div>

  <div class="sticky-dock glass" data-sticky-dock>
    <div class="sticky-inner">
      <div class="sticky-copy">
        <strong>{{ product.title }} / {{ current_variant.price | money }}</strong>
        <span>Patented alignment feedback, free shaker while stocks last, same-store checkout.</span>
      </div>
      <a class="button" href="#snf-buy-box-{{ section.id }}">Buy now</a>
    </div>
  </div>

  <script>
    (() => {
      const root = document.getElementById("snf-levelup-{{ section.id }}");
      if (!root) return;

      const useCases = [
        {
          id: "rows",
          kicker: "Rows",
          label: "Rows",
          summary: "Keep the pull level when fatigue climbs.",
          title: "Rows are where the grip and alignment story click fastest.",
          text: "Rows make LevelUp easy to understand because both benefits are visible at once: a harder handle for more grip and forearm demand, and a level cue that keeps the pull from quietly drifting off balance.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A2557_square_crop_2000.webp?v=1769487620&width=1800",
          benefits: [
            "Makes forearm and bicep engagement feel more deliberate from the first rep.",
            "Turns hidden asymmetry into a visible correction point under load.",
            "Strong first use case for serious back and arm training."
          ]
        },
        {
          id: "curls",
          kicker: "Curls",
          label: "Curls",
          summary: "Sell the pump and the control in the same frame.",
          title: "If the buyer wants bigger arms, curls make the offer obvious.",
          text: "Curls let the page lean into the strongest growth hook without losing the balance story. The product becomes an easy add to an existing arm session instead of something that requires a new training system.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A2480_square_crop_2000.webp?v=1769488611&width=1800",
          benefits: [
            "Supports the “explosive arm pumps” and thick-grip growth promise from the live store.",
            "Makes the thicker handle feel instantly relevant for arm day buyers.",
            "Keeps the pitch simple: more grip demand, more control, more growth."
          ]
        },
        {
          id: "presses",
          kicker: "Presses",
          label: "Presses",
          summary: "Stop one side quietly stealing the rep.",
          title: "Pressing is where the alignment cue starts to feel protective as well as powerful.",
          text: "The script deck repeatedly leans on the injury and symmetry angle. Pressing movements are the clearest way to show why a visible level cue matters when one wrist, shoulder, or side of the bar starts drifting under fatigue.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A3029_square_crop_2000.webp?v=1767933896&width=1800",
          benefits: [
            "Helps the buyer connect balance to joint strain reduction and cleaner movement.",
            "Strengthens the product’s performance-plus-protection positioning.",
            "Makes the patented cue feel like real engineering, not just novelty."
          ]
        },
        {
          id: "pulls",
          kicker: "Pulls",
          label: "Pulls",
          summary: "Turn grip from bottleneck into foundation.",
          title: "Heavy pulling makes the grip-strength story more serious.",
          text: "When the handle gets more demanding, pulls feel like a test of real grip capacity rather than just another accessory demo. That expands the page beyond arm-day vanity and into serious performance territory.",
          image: "https://sniperform.com.au/cdn/shop/files/0F3A2747.png?v=1738733865&width=1400",
          benefits: [
            "Supports the live store’s hand-crushing grip strength angle.",
            "Shows the product belongs in more than one exercise slot.",
            "Makes the tool feel useful for advanced lifters, not just casual buyers."
          ]
        }
      ];

      const tabWrap = root.querySelector("[data-use-tabs]");
      const useImage = root.querySelector("[data-use-image]");
      const useKicker = root.querySelector("[data-use-kicker]");
      const useTitle = root.querySelector("[data-use-title]");
      const useText = root.querySelector("[data-use-text]");
      const useBenefits = root.querySelector("[data-use-benefits]");
      const qtyDisplays = [...root.querySelectorAll("[data-qty-display]")];
      const qtyInputs = [...root.querySelectorAll("[data-qty-input]")];
      const qtyIncrease = [...root.querySelectorAll("[data-qty-increase]")];
      const qtyDecrease = [...root.querySelectorAll("[data-qty-decrease]")];
      const buyNowLinks = [...root.querySelectorAll("[data-buy-now]")];
      const stickyDock = root.querySelector("[data-sticky-dock]");
      const autoVideos = [...root.querySelectorAll("[data-auto-video]")];
      const revealNodes = [...root.querySelectorAll(".reveal")];
      let quantity = 1;

      function setUseCase(id){
        const item = useCases.find((entry) => entry.id === id) || useCases[0];
        tabWrap.innerHTML = useCases.map((entry) => `
          <button class="use-tab${entry.id === item.id ? " active" : ""}" type="button" data-use-id="${entry.id}">
            <small class="mono">${entry.label}</small>
            <strong>${entry.summary}</strong>
            <span>${entry.id === item.id ? "Currently selected" : "View this use case"}</span>
          </button>
        `).join("");
        useImage.src = item.image;
        useImage.alt = `${item.label} use case with Sniperform LevelUp`;
        useKicker.textContent = item.kicker;
        useTitle.textContent = item.title;
        useText.textContent = item.text;
        useBenefits.innerHTML = item.benefits.map((benefit) => `<div class="use-benefit">${benefit}</div>`).join("");
      }

      function syncQuantity(next){
        quantity = Math.max(1, Number.isFinite(next) ? Math.floor(next) : 1);
        qtyDisplays.forEach((input) => input.value = String(quantity));
        qtyInputs.forEach((input) => input.value = "{{ current_variant.id }}");
        buyNowLinks.forEach((link) => { link.href = `/cart/{{ current_variant.id }}:${quantity}`; });
      }

      function updateDock(){
        if (!stickyDock) return;
        stickyDock.classList.toggle("show", window.scrollY > root.offsetTop + 820);
      }

      setUseCase("rows");
      syncQuantity(1);
      updateDock();

      tabWrap.addEventListener("click", (event) => {
        const button = event.target.closest("[data-use-id]");
        if (!button) return;
        setUseCase(button.dataset.useId);
      });

      qtyIncrease.forEach((button) => button.addEventListener("click", () => syncQuantity(quantity + 1)));
      qtyDecrease.forEach((button) => button.addEventListener("click", () => syncQuantity(quantity - 1)));
      qtyDisplays.forEach((input) => input.addEventListener("input", () => syncQuantity(Number(input.value))));

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("in");
        });
      }, { threshold: 0.14 });
      revealNodes.forEach((node) => revealObserver.observe(node));

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const videoObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const video = entry.target;
          if (reducedMotion) {
            video.pause();
            return;
          }
          if (entry.isIntersecting) video.play().catch(() => {});
          else video.pause();
        });
      }, { threshold: 0.35 });
      autoVideos.forEach((video) => videoObserver.observe(video));

      window.addEventListener("scroll", updateDock, { passive: true });
    })();
  </script>
</section>

{% schema %}
{
  "name": "Sniperform LevelUp Product",
  "settings": [
    {
      "type": "text",
      "id": "offer_heading",
      "label": "Offer heading",
      "default": "FREE shaker included"
    },
    {
      "type": "textarea",
      "id": "offer_text",
      "label": "Offer text",
      "default": "Buy LevelUp Grips and your free Sniperform Shaker is applied automatically at checkout. No code. No extra clicks."
    },
    {
      "type": "text",
      "id": "founder_heading",
      "label": "Founder heading",
      "default": "The product story becomes stronger when the founder problem is specific."
    },
    {
      "type": "textarea",
      "id": "founder_quote",
      "label": "Founder quote",
      "default": "After 20 years of lifting, I realised one side of my body always did more work. My chest was uneven, my posture twisted, and eventually my shoulder tore."
    },
    {
      "type": "text",
      "id": "founder_attribution",
      "label": "Founder attribution",
      "default": "Darren / Founder script"
    },
    {
      "type": "text",
      "id": "final_heading",
      "label": "Final CTA heading",
      "default": "Ready to stop guessing through your reps?"
    },
    {
      "type": "textarea",
      "id": "final_text",
      "label": "Final CTA text",
      "default": "LevelUp gives you the thick-grip arm-growth story buyers already want, then adds the patented balance feedback that makes the offer feel smarter, more useful, and easier to justify."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Will LevelUp fit my bars and dumbbells?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Yes. The current live store positions LevelUp for standard Olympic barbells and dumbbells in the 28–32mm range."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sniperform LevelUp Product"
    }
  ]
}
{% endschema %}
