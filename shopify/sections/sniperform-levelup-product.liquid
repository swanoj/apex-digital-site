{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign media_hero = product.featured_media | default: product.media.first
  assign media_lifestyle = product.media[1] | default: media_hero
  assign media_detail = product.media[2] | default: media_lifestyle
  assign media_setup = product.media[3] | default: media_detail
%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<section id="snf-levelup-{{ section.id }}" class="snf-levelup">
  <style>
    #snf-levelup-{{ section.id }}{
      --mint:#00c4b3;
      --mint-deep:#006b69;
      --mint-soft:#e9fffb;
      --ink:#202730;
      --ink-2:#333e48;
      --slate:#626872;
      --line:rgba(51,62,72,.14);
      --line-strong:rgba(51,62,72,.22);
      --paper:#f7fbfb;
      --white:#fff;
      --shadow:0 24px 70px rgba(20,32,40,.08);
      --shadow-strong:0 35px 90px rgba(0,30,40,.16);
      --radius:28px;
      --ease:cubic-bezier(.22,.8,.18,1);
      color:var(--ink);
      font-family:"Montserrat",sans-serif;
      background:
        radial-gradient(circle at 14% 0%, rgba(0,196,179,.13), transparent 26%),
        radial-gradient(circle at 100% 18%, rgba(0,107,105,.10), transparent 20%),
        linear-gradient(180deg,#ffffff 0%, #f7fbfb 44%, #ffffff 100%);
      overflow:hidden;
    }
    #snf-levelup-{{ section.id }} *{box-sizing:border-box}
    #snf-levelup-{{ section.id }} img,
    #snf-levelup-{{ section.id }} video{display:block;max-width:100%}
    #snf-levelup-{{ section.id }} a{text-decoration:none}
    #snf-levelup-{{ section.id }} button,
    #snf-levelup-{{ section.id }} input{font:inherit}
    #snf-levelup-{{ section.id }} .wrap{width:min(1240px,calc(100% - 28px));margin:0 auto}
    #snf-levelup-{{ section.id }} .mono{font-family:"IBM Plex Mono",monospace;letter-spacing:.16em;text-transform:uppercase}
    #snf-levelup-{{ section.id }} .eyebrow{display:inline-flex;align-items:center;gap:12px;color:var(--mint-deep);font-size:12px;font-weight:500}
    #snf-levelup-{{ section.id }} .eyebrow::before{content:"";width:28px;height:1px;background:rgba(0,107,105,.35)}
    #snf-levelup-{{ section.id }} .section-head{max-width:720px;margin-bottom:32px}
    #snf-levelup-{{ section.id }} .section-head h2{margin-top:18px;font-size:clamp(34px,4.5vw,56px);line-height:.96;letter-spacing:-.06em;font-weight:800}
    #snf-levelup-{{ section.id }} .section-head p{margin-top:16px;color:var(--slate);font-size:16px;line-height:1.78}
    #snf-levelup-{{ section.id }} .card{border-radius:var(--radius);border:1px solid var(--line);background:rgba(255,255,255,.95);box-shadow:var(--shadow)}
    #snf-levelup-{{ section.id }} .card-dark{border-radius:var(--radius);border:1px solid rgba(255,255,255,.09);background:linear-gradient(160deg, rgba(255,255,255,.08), rgba(255,255,255,.02)),linear-gradient(180deg, #28313a 0%, #1b232b 100%);color:#fff;box-shadow:var(--shadow-strong)}
    #snf-levelup-{{ section.id }} .glass{background:rgba(255,255,255,.88);border:1px solid rgba(255,255,255,.7);box-shadow:var(--shadow);backdrop-filter:blur(18px)}
    #snf-levelup-{{ section.id }} .button,
    #snf-levelup-{{ section.id }} .button-ghost,
    #snf-levelup-{{ section.id }} .button-dark{display:inline-flex;align-items:center;justify-content:center;min-height:54px;padding:14px 22px;border-radius:999px;font-weight:800;transition:transform .24s var(--ease), box-shadow .24s var(--ease), background .24s var(--ease), border-color .24s var(--ease)}
    #snf-levelup-{{ section.id }} .button{color:#fff;background:linear-gradient(135deg,var(--mint),var(--mint-deep));box-shadow:0 14px 34px rgba(0,107,105,.24)}
    #snf-levelup-{{ section.id }} .button-dark{color:#fff;background:var(--ink);box-shadow:0 12px 28px rgba(32,39,48,.18)}
    #snf-levelup-{{ section.id }} .button-ghost{border:1px solid var(--line-strong);color:var(--ink);background:rgba(255,255,255,.7)}
    #snf-levelup-{{ section.id }} .button:hover,
    #snf-levelup-{{ section.id }} .button-dark:hover,
    #snf-levelup-{{ section.id }} .button-ghost:hover{transform:translateY(-2px)}
    #snf-levelup-{{ section.id }} .pill{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.88);color:var(--ink-2);font-size:12px;font-weight:600}
    #snf-levelup-{{ section.id }} .pill::before{content:"";width:8px;height:8px;border-radius:999px;background:linear-gradient(135deg,var(--mint),var(--mint-deep))}

    #snf-levelup-{{ section.id }} .announcement{border-bottom:1px solid rgba(255,255,255,.4);background:linear-gradient(90deg,#ddfff9 0%, #f7fffd 52%, #f1fbfb 100%)}
    #snf-levelup-{{ section.id }} .announcement .wrap{min-height:42px;display:flex;align-items:center;justify-content:center;gap:18px;flex-wrap:wrap;color:var(--ink-2);font-size:11px;font-weight:700}
    #snf-levelup-{{ section.id }} .announcement span{display:inline-flex;align-items:center;gap:10px}
    #snf-levelup-{{ section.id }} .announcement span::before{content:"";width:6px;height:6px;border-radius:999px;background:var(--mint)}

    #snf-levelup-{{ section.id }} .hero{padding:44px 0 32px}
    #snf-levelup-{{ section.id }} .hero-shell{display:grid;grid-template-columns:minmax(0,.82fr) minmax(0,1.18fr);gap:28px;align-items:start}
    #snf-levelup-{{ section.id }} .hero-copy{padding:22px 0}
    #snf-levelup-{{ section.id }} .hero-copy h1{margin-top:18px;font-size:clamp(52px,8vw,94px);line-height:.9;letter-spacing:-.08em;font-weight:900;max-width:10.3ch}
    #snf-levelup-{{ section.id }} .hero-copy .accent{color:var(--mint-deep)}
    #snf-levelup-{{ section.id }} .hero-copy p{max-width:640px;margin-top:18px;color:var(--slate);font-size:17px;line-height:1.82}
    #snf-levelup-{{ section.id }} .hero-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:28px}
    #snf-levelup-{{ section.id }} .hero-trust{display:flex;flex-wrap:wrap;gap:10px;margin-top:22px}
    #snf-levelup-{{ section.id }} .hero-proofline{display:flex;align-items:center;gap:14px;margin-top:22px;color:var(--ink-2);font-size:13px;font-weight:700}
    #snf-levelup-{{ section.id }} .hero-stars{color:var(--mint-deep);letter-spacing:.18em;font-size:14px}

    #snf-levelup-{{ section.id }} .hero-right{display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:20px}
    #snf-levelup-{{ section.id }} .product-stage{position:relative;min-height:620px;padding:28px;overflow:hidden;border-radius:34px;border:1px solid rgba(255,255,255,.72);box-shadow:var(--shadow)}
    #snf-levelup-{{ section.id }} .stage-grid{position:absolute;inset:0;background:linear-gradient(rgba(51,62,72,.06) 1px, transparent 1px),linear-gradient(90deg, rgba(51,62,72,.06) 1px, transparent 1px);background-size:64px 64px;mask-image:linear-gradient(180deg, rgba(0,0,0,.5), transparent 82%)}
    #snf-levelup-{{ section.id }} .stage-ring{position:absolute;inset:70px 40px auto auto;width:380px;aspect-ratio:1;border-radius:50%;border:1px solid rgba(0,107,105,.12);background:radial-gradient(circle, rgba(255,255,255,.64) 0%, rgba(255,255,255,.16) 45%, transparent 72%)}
    #snf-levelup-{{ section.id }} .stage-product-card{position:absolute;left:50%;bottom:24px;z-index:2;width:min(390px,78%);padding:16px;border-radius:30px;background:rgba(255,255,255,.94);border:1px solid rgba(255,255,255,.9);box-shadow:0 28px 50px rgba(0,40,46,.16);transform:translateX(-50%)}
    #snf-levelup-{{ section.id }} .stage-product{display:block;width:100%;height:auto}
    #snf-levelup-{{ section.id }} .stage-badge,#snf-levelup-{{ section.id }} .stage-quote{position:absolute;z-index:3;max-width:240px;padding:18px 18px 16px}
    #snf-levelup-{{ section.id }} .stage-badge small,#snf-levelup-{{ section.id }} .stage-quote small{display:block;color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    #snf-levelup-{{ section.id }} .stage-badge strong,#snf-levelup-{{ section.id }} .stage-quote strong{display:block;margin-top:8px;font-size:17px;line-height:1.28;letter-spacing:-.04em}
    #snf-levelup-{{ section.id }} .stage-badge p,#snf-levelup-{{ section.id }} .stage-quote p{margin-top:8px;color:var(--slate);font-size:13px;line-height:1.6}
    #snf-levelup-{{ section.id }} .stage-badge.one{top:20px;left:20px;max-width:220px;padding:14px 16px}
    #snf-levelup-{{ section.id }} .stage-badge.one strong{font-size:15px}
    #snf-levelup-{{ section.id }} .stage-badge.one p{display:none}
    #snf-levelup-{{ section.id }} .stage-badge.two{bottom:30px;left:26px}
    #snf-levelup-{{ section.id }} .stage-quote{right:22px;bottom:24px;max-width:250px}
    #snf-levelup-{{ section.id }} .stage-inset{display:none}

    #snf-levelup-{{ section.id }} .buy-card{padding:22px;align-self:end}
    #snf-levelup-{{ section.id }} .buy-kicker{display:flex;align-items:center;justify-content:space-between;gap:10px;color:rgba(255,255,255,.74);font-size:11px}
    #snf-levelup-{{ section.id }} .buy-kicker span:last-child{color:#8df0e4;font-weight:700}
    #snf-levelup-{{ section.id }} .buy-card h2{margin-top:18px;font-size:28px;line-height:.96;letter-spacing:-.05em}
    #snf-levelup-{{ section.id }} .buy-card p{margin-top:14px;color:rgba(255,255,255,.78);font-size:14px;line-height:1.75}
    #snf-levelup-{{ section.id }} .price-row{display:flex;align-items:end;justify-content:space-between;gap:16px;margin-top:20px}
    #snf-levelup-{{ section.id }} .price-row strong{font-size:40px;line-height:.92;letter-spacing:-.06em}
    #snf-levelup-{{ section.id }} .price-row span{max-width:132px;color:#97fff0;font-size:12px;font-weight:700;text-align:right}
    #snf-levelup-{{ section.id }} .offer{margin-top:16px;padding:14px 16px;border-radius:20px;background:rgba(0,196,179,.12);border:1px solid rgba(141,240,228,.2)}
    #snf-levelup-{{ section.id }} .offer strong{display:block;color:#fff;font-size:13px;letter-spacing:.12em;text-transform:uppercase}
    #snf-levelup-{{ section.id }} .offer p{margin-top:6px;color:#ddfff9;font-size:12px;line-height:1.55}
    #snf-levelup-{{ section.id }} .buy-visual{margin-top:18px;padding:14px;border-radius:22px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);display:flex;justify-content:center}
    #snf-levelup-{{ section.id }} .buy-visual img{width:min(220px,72%);border-radius:16px}
    #snf-levelup-{{ section.id }} .buy-bullets{display:grid;gap:10px;margin-top:18px;padding:0}
    #snf-levelup-{{ section.id }} .buy-bullets li{list-style:none;display:flex;gap:10px;color:#fff;font-size:13px;line-height:1.6}
    #snf-levelup-{{ section.id }} .buy-bullets li::before{content:"";flex:0 0 8px;width:8px;height:8px;border-radius:999px;margin-top:7px;background:#8df0e4}
    #snf-levelup-{{ section.id }} .buy-proof{margin-top:18px;padding-top:18px;border-top:1px solid rgba(255,255,255,.09)}
    #snf-levelup-{{ section.id }} .buy-proof blockquote{color:#fff;font-size:15px;line-height:1.72;font-weight:600}
    #snf-levelup-{{ section.id }} .buy-proof cite{display:block;margin-top:10px;color:rgba(255,255,255,.68);font-size:12px;font-style:normal}
    #snf-levelup-{{ section.id }} .checkout{display:grid;gap:12px;margin-top:22px}
    #snf-levelup-{{ section.id }} .qty{display:grid;grid-template-columns:48px 1fr 48px;min-height:54px;border-radius:999px;overflow:hidden;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06)}
    #snf-levelup-{{ section.id }} .qty button{border:0;color:#fff;background:transparent;font-size:24px;cursor:pointer}
    #snf-levelup-{{ section.id }} .qty input{border:0;background:transparent;color:#fff;text-align:center;outline:none;font-size:16px;font-weight:700}
    #snf-levelup-{{ section.id }} .cart-form button,
    #snf-levelup-{{ section.id }} .buy-now{width:100%}
    #snf-levelup-{{ section.id }} .cart-form button{border:0;cursor:pointer}
    #snf-levelup-{{ section.id }} .buy-now{border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06);color:#fff}
    #snf-levelup-{{ section.id }} .buy-note{color:rgba(255,255,255,.62);font-size:11px;line-height:1.55;text-align:center}

    #snf-levelup-{{ section.id }} .metrics{padding:14px 0 34px}
    #snf-levelup-{{ section.id }} .metric-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:14px}
    #snf-levelup-{{ section.id }} .metric{padding:22px 18px;border-radius:24px}
    #snf-levelup-{{ section.id }} .metric strong{display:block;font-size:28px;line-height:.94;letter-spacing:-.06em}
    #snf-levelup-{{ section.id }} .metric span{display:block;margin-top:10px;color:var(--slate);font-size:12px;line-height:1.55;text-transform:uppercase;letter-spacing:.08em;font-weight:700}

    #snf-levelup-{{ section.id }} .why{padding:44px 0 32px}
    #snf-levelup-{{ section.id }} .why-shell{display:grid;grid-template-columns:minmax(0,.96fr) minmax(0,1.04fr);gap:28px;align-items:start}
    #snf-levelup-{{ section.id }} .why-copy{display:grid;gap:14px}
    #snf-levelup-{{ section.id }} .why-card{padding:22px 22px 20px}
    #snf-levelup-{{ section.id }} .why-card strong{display:block;font-size:20px;line-height:1.14;letter-spacing:-.04em}
    #snf-levelup-{{ section.id }} .why-card p{margin-top:10px;color:var(--slate);font-size:14px;line-height:1.78}
    #snf-levelup-{{ section.id }} .why-media{display:grid;grid-template-columns:1.25fr .75fr;gap:14px}
    #snf-levelup-{{ section.id }} .why-media .stack{display:grid;gap:14px}
    #snf-levelup-{{ section.id }} .media-card{position:relative;overflow:hidden;border-radius:28px;border:1px solid var(--line);box-shadow:var(--shadow)}
    #snf-levelup-{{ section.id }} .media-card img{width:100%;height:100%;object-fit:cover}
    #snf-levelup-{{ section.id }} .media-card.tall{min-height:540px}
    #snf-levelup-{{ section.id }} .media-card.medium{min-height:262px}
    #snf-levelup-{{ section.id }} .media-label{position:absolute;left:16px;right:16px;bottom:16px;padding:14px 16px;border-radius:20px}
    #snf-levelup-{{ section.id }} .media-label strong{display:block;font-size:16px;line-height:1.18;letter-spacing:-.04em}
    #snf-levelup-{{ section.id }} .media-label p{margin-top:8px;color:rgba(255,255,255,.72);font-size:12px;line-height:1.58}

    #snf-levelup-{{ section.id }} .use-cases{padding:42px 0 34px}
    #snf-levelup-{{ section.id }} .use-shell{display:grid;grid-template-columns:260px minmax(0,1fr);gap:20px;align-items:start}
    #snf-levelup-{{ section.id }} .use-nav{display:grid;gap:12px}
    #snf-levelup-{{ section.id }} .use-tab{padding:18px 18px 16px;border:1px solid var(--line);border-radius:24px;background:rgba(255,255,255,.84);text-align:left;cursor:pointer;transition:border-color .24s var(--ease), transform .24s var(--ease), box-shadow .24s var(--ease)}
    #snf-levelup-{{ section.id }} .use-tab.active{border-color:rgba(0,107,105,.24);box-shadow:var(--shadow);transform:translateX(4px)}
    #snf-levelup-{{ section.id }} .use-tab small{display:block;color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    #snf-levelup-{{ section.id }} .use-tab strong{display:block;margin-top:8px;font-size:18px;line-height:1.14;letter-spacing:-.04em}
    #snf-levelup-{{ section.id }} .use-tab span{display:block;margin-top:8px;color:var(--slate);font-size:13px;line-height:1.6}
    #snf-levelup-{{ section.id }} .use-panel{overflow:hidden;display:grid;grid-template-columns:minmax(0,.88fr) minmax(0,1.12fr)}
    #snf-levelup-{{ section.id }} .use-image{min-height:540px;background:#d9ece8}
    #snf-levelup-{{ section.id }} .use-image img{width:100%;height:100%;object-fit:cover}
    #snf-levelup-{{ section.id }} .use-copy{padding:34px}
    #snf-levelup-{{ section.id }} .use-copy small{color:var(--mint-deep);font-size:12px;font-weight:800;letter-spacing:.18em;text-transform:uppercase}
    #snf-levelup-{{ section.id }} .use-copy h3{margin-top:18px;font-size:clamp(30px,3vw,44px);line-height:.96;letter-spacing:-.06em}
    #snf-levelup-{{ section.id }} .use-copy p{margin-top:16px;color:var(--slate);font-size:15px;line-height:1.82}
    #snf-levelup-{{ section.id }} .use-benefits{display:grid;gap:12px;margin-top:20px}
    #snf-levelup-{{ section.id }} .use-benefit{padding:16px 18px;border-radius:20px;border:1px solid var(--line);background:var(--paper);font-size:14px;line-height:1.68;color:var(--ink-2);font-weight:600}

    #snf-levelup-{{ section.id }} .engineering{padding:44px 0 30px}
    #snf-levelup-{{ section.id }} .engineering-shell{display:grid;grid-template-columns:minmax(0,1.04fr) minmax(0,.96fr);gap:24px;align-items:start}
    #snf-levelup-{{ section.id }} .engineering-media{display:grid;gap:14px}
    #snf-levelup-{{ section.id }} .engineering-media .card{overflow:hidden}
    #snf-levelup-{{ section.id }} .engineering-media img{width:100%;height:auto}
    #snf-levelup-{{ section.id }} .engineering-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    #snf-levelup-{{ section.id }} .spec-card{padding:20px}
    #snf-levelup-{{ section.id }} .spec-card small{display:block;color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    #snf-levelup-{{ section.id }} .spec-card strong{display:block;margin-top:8px;font-size:20px;line-height:1.12;letter-spacing:-.05em}
    #snf-levelup-{{ section.id }} .spec-card p{margin-top:10px;color:var(--slate);font-size:13px;line-height:1.68}
    #snf-levelup-{{ section.id }} .founder{margin-top:16px;padding:24px}
    #snf-levelup-{{ section.id }} .founder h3{font-size:34px;line-height:.94;letter-spacing:-.06em}
    #snf-levelup-{{ section.id }} .founder p{margin-top:16px;color:var(--slate);font-size:15px;line-height:1.85}
    #snf-levelup-{{ section.id }} .founder blockquote{margin-top:20px;padding-top:20px;border-top:1px solid var(--line);color:var(--ink);font-size:18px;line-height:1.65;font-weight:700}
    #snf-levelup-{{ section.id }} .founder cite{display:block;margin-top:12px;color:var(--slate);font-size:12px;font-style:normal;text-transform:uppercase;letter-spacing:.12em;font-weight:700}

    #snf-levelup-{{ section.id }} .proof{padding:44px 0 32px}
    #snf-levelup-{{ section.id }} .proof-shell{display:grid;grid-template-columns:minmax(0,.92fr) minmax(0,1.08fr);gap:24px;align-items:start}
    #snf-levelup-{{ section.id }} .quote-video{overflow:hidden}
    #snf-levelup-{{ section.id }} .quote-copy{padding:28px}
    #snf-levelup-{{ section.id }} .quote-copy blockquote{font-size:28px;line-height:1.26;letter-spacing:-.05em;font-weight:800}
    #snf-levelup-{{ section.id }} .quote-copy p{margin-top:14px;color:var(--slate);font-size:15px;line-height:1.82}
    #snf-levelup-{{ section.id }} .quote-copy cite{display:block;margin-top:14px;color:var(--mint-deep);font-size:12px;font-style:normal;text-transform:uppercase;letter-spacing:.14em;font-weight:800}
    #snf-levelup-{{ section.id }} .quote-media{background:#0e141a}
    #snf-levelup-{{ section.id }} .quote-media video{width:100%;aspect-ratio:16 / 10;object-fit:cover;background:#0e141a}
    #snf-levelup-{{ section.id }} .proof-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    #snf-levelup-{{ section.id }} .proof-item{overflow:hidden}
    #snf-levelup-{{ section.id }} .proof-item video{width:100%;aspect-ratio:4 / 5;object-fit:cover;background:#091114}
    #snf-levelup-{{ section.id }} .proof-caption{padding:16px}
    #snf-levelup-{{ section.id }} .proof-caption small{color:var(--mint-deep);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
    #snf-levelup-{{ section.id }} .proof-caption strong{display:block;margin-top:8px;font-size:18px;line-height:1.12;letter-spacing:-.04em}
    #snf-levelup-{{ section.id }} .proof-caption p{margin-top:8px;color:var(--slate);font-size:13px;line-height:1.66}

    #snf-levelup-{{ section.id }} .compare{padding:42px 0 30px}
    #snf-levelup-{{ section.id }} .compare-panel{overflow:hidden}
    #snf-levelup-{{ section.id }} .compare-head,#snf-levelup-{{ section.id }} .compare-row{display:grid;grid-template-columns:1.2fr .9fr .9fr;gap:18px;align-items:center}
    #snf-levelup-{{ section.id }} .compare-head{padding:18px 22px;background:#eff8f7;border-bottom:1px solid var(--line);font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.14em;color:var(--slate)}
